# ==================== .gitattributes ====================
# 统一跨平台文本文件编码与换行符，防止 Windows 编辑器误存为 UTF-16/CRLF
# 导致 Linux 容器（pip / npm / nginx / shell）解析失败。
#
# 约定：
#   - 文本文件一律 UTF-8（无 BOM）、LF 换行
#   - 二进制文件不做任何转换
# ========================================================

# 默认：所有文件按文本自动识别，统一 LF 换行
* text=auto eol=lf

# ---- 明确强制 LF（容器内执行的脚本 / 配置，CRLF 会致命）----
*.sh         text eol=lf
*.py         text eol=lf
Dockerfile*  text eol=lf
*.dockerfile text eol=lf
*.conf       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.toml       text eol=lf
*.json       text eol=lf
*.txt        text eol=lf
*.md         text eol=lf
*.cfg        text eol=lf
*.ini        text eol=lf
*.env*       text eol=lf
*.http       text eol=lf
justfile     text eol=lf
*.justfile   text eol=lf

# ---- 前端 ----
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.css        text eol=lf
*.html       text eol=lf
*.svg        text eol=lf

# ---- Windows 专用脚本保留 CRLF ----
*.ps1        text eol=crlf
*.bat        text eol=crlf
*.cmd        text eol=crlf

# ---- 二进制文件（不做转换）----
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.webp       binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.tar        binary
*.gz         binary
*.egg        binary
*.whl        binary
*.pyc        binary
*.pyd        binary
*.so         binary
*.dll        binary
*.dylib      binary
