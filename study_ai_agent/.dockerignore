# ==================== 后端 .dockerignore ====================
# 避免把本地缓存、虚拟环境、敏感配置打入镜像
# ===================================================

# 虚拟环境
.venv/
venv/
env/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/

# 测试产物
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
.tox/

# 敏感配置 / 运行时数据
.env
.env.*
!.env.example
logs/
*.log
*.jsonl

# IDE / 系统
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker 自身
Dockerfile
.dockerignore

# 文档与示例（如果做最小镜像可以保留；这里打包更小的 runtime）
# docs/
# *.md
