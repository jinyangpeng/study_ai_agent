# ==================== 后端 .env.example ====================
# 复制为 .env.development / .env.production 后填入真实值：
#   cp .env.example .env.development
#   cp .env.example .env.production
# 任何值为空时，对应供应商在启动日志中会打 "unavailable"，
# 但只要至少一个 LLM API Key 非空，agent 就能跑。
# =========================================================

ENV=development

# ---- 模型调度策略（priority / round_robin / random） ----
AGENT_STRATEGY=priority

# ---- 各家厂商的 API Key（至少填一个） ----
# 阿里通义千问 / DashScope
DASHSCOPE_API_KEY=
# DeepSeek
DEEPSEEK_API_KEY=
# 智谱 GLM / Z.ai
ZAI_API_KEY=
# 百度千帆
QIANFAN_API_KEY=

# ---- 各家厂商的 OpenAI 兼容 base URL ----
# 默认指向厂商官方端点；可通过取消注释并改值的方式覆盖。
# 常见场景：企业内代理 / 网关、跨地域加速、自部署兼容 OpenAI 协议的服务。
# 留空时由 provider 的 ModelConfig.base_url 兜底（等于下面注释里的默认值）。
#
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2

# ---- 应用 ----
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ---- PostgreSQL（langgraph checkpointer 后端）----
# 单机开发：POSTGRES_HOST=localhost
# 容器编排：POSTGRES_HOST=postgres  （docker compose 服务名）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
POSTGRES_SCHEMA=langgraph_checkpoints
# 连接池（AsyncConnectionPool）
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_POOL_TIMEOUT=30
# 后端选择：postgres（默认） | memory（仅 dev 无 DB 时回退）
CHECKPOINTER_BACKEND=postgres
