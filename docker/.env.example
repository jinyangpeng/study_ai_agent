# ==================== .env.example (Docker / compose 通用) ====================
# 复制为 .env 后填入真实值。
#   cd docker
#   cp .env.example .env
#   docker compose up -d
#
# 任何值为空时，后端启动会打 "XXX API key not configured, unavailable"，
# 但只要至少一个 LLM API Key 非空，agent 就能跑。
# =================================================================

# ---- 端口映射（宿主机:容器） ----
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ---- 日志级别 ----
LOG_LEVEL=INFO

# ---- 前端构建期变量（浏览器看到的后端地址） ----
# 同主机 compose 网络：浏览器在主机上跑就用 http://localhost:8000
# 全部在容器内：可以用 http://backend:8000
VITE_APP_TITLE=Study AI Agent
VITE_API_BASE_URL=http://localhost:8000
VITE_HEALTH_CHECK_URL=http://localhost:8000/health

# ---- 模型调度策略（priority / round_robin / random） ----
AGENT_STRATEGY=priority

# ---- PostgreSQL（langgraph checkpointer 持久化）----
# 两种模式：
#   A) 默认：连外部已部署的 PostgreSQL —— 在这里填连接信息即可
#   B) 内置：COMPOSE_PROFILES=with-postgres docker compose up -d
#      会额外起一个 postgres:16-alpine，POSTGRES_HOST 自动指向它
#
# 模式 A（默认，外部 PG）：填你的 PG 地址
POSTGRES_HOST=your-pg-host.example.com
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_SCHEMA=langgraph_checkpoints
# checkpointer 后端：postgres（默认，持久化）| memory（仅 dev 无 DB 时回退，重启丢状态）
CHECKPOINTER_BACKEND=postgres
#
# 模式 B（内置 PG）：把 POSTGRES_HOST 改回 postgres（compose 服务名），
# 或直接用 COMPOSE_PROFILES=with-postgres 启动（compose 会自动用 postgres 服务名）。
# POSTGRES_HOST=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=postgres

# ---- LLM API Key（至少填一个） ----
# 阿里通义千问 / DashScope
DASHSCOPE_API_KEY=
# DeepSeek
DEEPSEEK_API_KEY=
# 智谱 GLM
ZAI_API_KEY=
# 千帆
QIANFAN_API_KEY=

# ---- 各家厂商的 OpenAI 兼容 base URL（可选；不填走 provider 内部默认） ----
# 常见场景：企业内代理 / 网关、跨地域加速、自部署兼容 OpenAI 协议的服务。
#
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2

# ---- 网络类工具的代理（按工具白名单） ----
# 默认所有工具走直连；只有 TOOL_PROXY_WHITELIST 列出的 tool 会临时切 HTTP_PROXY，
# 调用完立刻还原，不污染 LLM 供应商调用。
#
# 用法：
#   1) 解开 TOOL_HTTP_PROXY 注释 + 填你的代理地址
#   2) TOOL_PROXY_WHITELIST 写上需要走代理的 tool 名称（逗号分隔）
#      可选值（与 langchain BaseTool.name 一致）：
#        - wikipedia                （知识库工具）
#        - duckduckgo_results_json  （Web 搜索工具）
#   3) 留空 / 注释掉白名单 → 等价于"所有工具直连"
#
# 完整说明见 study_ai_agent/src/core/tools/proxy.py 顶部 docstring。
#
# TOOL_HTTP_PROXY=http://127.0.0.1:10809
# TOOL_PROXY_WHITELIST=wikipedia,duckduckgo_results_json

# ---- MCP 服务（热插拔外部工具服务）----
# 格式：name=url,name=url（逗号分隔）
# agent 启动时通过 langchain-mcp-adapters 连接每个 server 拉工具
# server 不可达时降级为空工具集，不阻塞 agent 启动
# 热重载：POST /admin/skills/reload 可在运行期重新连接（不用重启进程）
#
# CRM MCP 服务（crm_mcp/ 目录）默认监听 :8001/mcp
MCP_SERVERS=crm=http://localhost:8001/mcp
