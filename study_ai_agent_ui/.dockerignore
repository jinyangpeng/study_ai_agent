# ==================== 前端 .dockerignore ====================
# =========================================

# 依赖
node_modules/

# 构建产物（容器内会重新构建）
dist/
build/

# 环境文件
.env
.env.local
.env.*.local

# 测试与覆盖率
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# IDE / 系统
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker 自身
Dockerfile
.dockerignore
nginx.conf
